{
  "name": "cicd-demo-app",
  "version": "1.0.0",
  "description": "A complete CI/CD example project with Node.js, GitHub Actions, and Docker",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node app.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ app.js --fix",
    "lint:check": "eslint src/ app.js",
    "build": "echo 'Build complete!'",
    "docker:build": "docker build -t cicd-demo-app .",
    "docker:run": "docker run -p 3000:3000 cicd-demo-app",
    "health": "curl http://localhost:3000/health || true"
  },
  "keywords": [
    "ci-cd",
    "github-actions",
    "docker",
    "nodejs",
    "automation"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.50.0",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
